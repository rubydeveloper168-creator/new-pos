{
    "name": "rubyshop/pos-system",
    "type": "project",
    "description": "RubyShop POS System - Ultimate POS Solution",
    "keywords": [
        "framework",
        "laravel",
        "pos",
        "point-of-sale"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4|^8.0",
        "aloha/twilio": "^4.0",
        "arcanedev/log-viewer": "^8.3",
        "barryvdh/laravel-dompdf": "*",
        "consoletvs/charts": "^6.9",
        "knox/pesapal": "^2.2",
        "laravel/framework": "8.83.29",
        "laravel/passport": "*",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^3.0|^4.0",
        "laravelcollective/html": "*",
        "maatwebsite/excel": "*",
        "milon/barcode": "*",
        "nwidart/laravel-menus": "dev-master",
        "nwidart/laravel-modules": "^9.0",
        "php-debugbar/php-debugbar": "^2.0",
        "pusher/pusher-php-server": "dev-master",
        "razorpay/razorpay": "^2.9",
        "rmccue/requests": "^2.0",
        "setasign/fpdi": "^2.0",
        "spatie/laravel-activitylog": "*",
        "spatie/laravel-backup": "*",
        "spatie/laravel-permission": "*",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^7.0",
        "unicodeveloper/laravel-paystack": "^1.0",
        "yajra/laravel-datatables-oracle": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.0.30"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Http/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
